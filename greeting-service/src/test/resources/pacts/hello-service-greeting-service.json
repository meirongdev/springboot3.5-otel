{
  "consumer": {
    "name": "hello-service"
  },
  "provider": {
    "name": "greeting-service"
  },
  "interactions": [
    {
      "type": "Synchronous/HTTP",
      "description": "get English greeting",
      "providerStates": [
        {
          "name": "greeting service is up"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/greetings",
        "headers": {
          "Accept-Language": "en"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "language": "en",
          "message": "Hello, World!"
        }
      }
    }
  ],
  "metadata": {
    "pactSpecification": {
      "version": "4.0"
    }
  }
}
