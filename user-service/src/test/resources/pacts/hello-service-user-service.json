{
  "consumer": {
    "name": "hello-service"
  },
  "provider": {
    "name": "user-service"
  },
  "interactions": [
    {
      "type": "Synchronous/HTTP",
      "description": "get user by id",
      "providerStates": [
        {
          "name": "user 1 exists"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/users/1"
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "id": 1,
          "name": "Alice",
          "email": "alice@example.com"
        }
      }
    }
  ],
  "metadata": {
    "pactSpecification": {
      "version": "4.0"
    }
  }
}
