# =============================================================================
# JDK_JAVA_OPTIONS Configuration for Production
# =============================================================================
# Usage: export JDK_JAVA_OPTIONS="$(cat jdk-java-options.env)"
# Or in Docker Compose: env_file:
#                         - jdk-java-options.env
# =============================================================================

# -----------------------------------------------------------------------------
# Memory Management (Percentage-based for Kubernetes/Containers)
# -----------------------------------------------------------------------------
# Max heap: 75% of container limit (safe default)
-XX:MaxRAMPercentage=75.0

# Initial heap: 50% (reduces startup GC)
-XX:InitialRAMPercentage=50.0

# -----------------------------------------------------------------------------
# Garbage Collector (G1GC - balanced throughput/latency)
# -----------------------------------------------------------------------------
-XX:+UseG1GC

# Target max GC pause time (adjust based on latency requirements)
-XX:MaxGCPauseMillis=200

# -----------------------------------------------------------------------------
# JFR (Java Flight Recorder) - Production Profiling
# -----------------------------------------------------------------------------
# Continuous recording with circular buffer (low overhead ~1-2%)
-XX:StartFlightRecording=name=production,maxsize=200m,maxage=2h,settings=profile

# Alternative: Debug mode (saves on exit for analysis)
# -XX:StartFlightRecording=name=debug,duration=60s,filename=/logs/profile.jfr,dumponexit=true

# -----------------------------------------------------------------------------
# GC Logging (for troubleshooting)
# -----------------------------------------------------------------------------
-Xlog:gc*:file=/logs/gc.log:time,uptime:filecount=5,filesize=10M

# -----------------------------------------------------------------------------
# Heap Dump on OOM (diagnostic)
# -----------------------------------------------------------------------------
-XX:+HeapDumpOnOutOfMemoryError
-XX:HeapDumpPath=/logs/
-XX:+ExitOnOutOfMemoryError

# -----------------------------------------------------------------------------
# Optional: Advanced Tuning (uncomment as needed)
# -----------------------------------------------------------------------------
# Prefer container-aware memory calculation (Java 10+)
# -XX:+UseContainerSupport

# String deduplication (reduces memory for string-heavy apps)
# -XX:+UseStringDeduplication

# Log class loading (debug classloader issues)
# -Xlog:class+load=info:class+unload=info:file=/logs/classloader.log

# -----------------------------------------------------------------------------
# Optional: Virtual Thread Tuning (Java 21+)
# -----------------------------------------------------------------------------
# Increase default carrier count for high concurrency
# -Djdk.virtualThreadScheduler.parallelism=256

# Detect pinned virtual threads (adds overhead, dev only)
# -Djdk.tracePinnedThreads=full
