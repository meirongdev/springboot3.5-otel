# EditorConfig helps maintain consistent coding styles across different editors and IDEs
# https://editorconfig.org

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Java files
[*.java]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# Kotlin files (Gradle build scripts)
[*.kts]
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# Properties files
[*.properties]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# XML files
[*.xml]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# Markdown files
[*.md]
trim_trailing_whitespace = false
insert_final_newline = true

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf

# Gradle wrapper properties (should not be modified)
[gradle/wrapper/gradle-wrapper.properties]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Docker files
[Dockerfile]
indent_style = space
indent_size = 2

# Docker Compose
[compose.yaml]
indent_style = space
indent_size = 2

# GitHub Actions workflows
[.github/workflows/*.yml]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
